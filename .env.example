# Server
PORT=8080
DATA_DIR=/data

# Set to 1 on prod: if agent_tickets is empty on boot (e.g. a fresh/wiped
# volume), self-seed the committed baseline from tickets.seed.json. No-op once
# the board has any tickets. Leave unset in dev.
SEED_ON_BOOT=1

# Music Tracker — see Widgets/Music Tracker/PROJECT.md for details
DJ_LIBRARY_PATH=/library
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_PLAYLIST_ID=
LIDARR_URL=http://nas.local:8686
