# Server
PORT=8080
DATA_DIR=/data

# Consistent SQLite snapshots (PD-33). All optional — sensible defaults below.
# Snapshots land in BACKUP_DIR (default <DATA_DIR>/backups) so whatever ships the
# data volume off-box (Hyper Backup today) carries a WAL-consistent copy.
# BACKUP_CRON=0 3 * * *          # schedule (default 03:00 daily)
# BACKUP_RETAIN_DAYS=14          # prune snapshots older than N days
# BACKUP_DIR=/data/backups       # output dir
# BACKUP_EXTRA_DB_PATHS=         # comma-separated extra DBs to snapshot (e.g. Sortie's .sortie.db)

# Set to 1 on prod: if agent_tickets is empty on boot (e.g. a fresh/wiped
# volume), self-seed the committed baseline from tickets.seed.json. No-op once
# the board has any tickets. Leave unset in dev.
SEED_ON_BOOT=1

# Agent Dashboard — GitHub label sync (PD-165). READ-ONLY token (contents/issues
# read on the sortie repos). When set, a cron job polls each linked issue's
# sortie:* labels and writes the derived status (in_progress/in_review/completed)
# + agent state onto the board. Unset = the sync is disabled (boots cleanly).
# The container also needs egress to api.github.com (squid allowlist).
# GITHUB_READ_TOKEN=

# Music Tracker — see Widgets/Music Tracker/PROJECT.md for details
DJ_LIBRARY_PATH=/library
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_PLAYLIST_ID=
LIDARR_URL=http://nas.local:8686
