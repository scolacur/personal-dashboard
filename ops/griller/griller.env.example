# Griller worker secrets/config (DECISIONS D-044, PD-266).
#
# Mounted at runtime as the griller container's env_file (see
# docker-compose.egress.yml). Kept SEPARATE from the web app's .env — the
# ANTHROPIC_API_KEY must never live in the user-facing web process.
#
# Copy to the deploy host as griller.env and fill in.

# Claude Agent SDK auth — pick ONE (the griller reaches api.anthropic.com only via the squid
# proxy; the credential can be read in-container but not exfiltrated off-allowlist):
#
#  (a) ANTHROPIC_API_KEY — metered pay-as-you-go, billed SEPARATELY from any Claude
#      subscription (a fresh key starts at $0 → add credits in the Console → Billing, or
#      you'll get "Credit balance is too low"). Cost-isolated; no shared quota.
#  (b) CLAUDE_CODE_OAUTH_TOKEN — your Claude Pro/Max subscription token (same one Sortie uses;
#      copy from sortie.env or run `claude setup-token`). No extra billing, but it SHARES the
#      Pro session quota with Sortie — and the griller defaults to Opus, which is heavy on that
#      quota, so consider GRILLER_MODEL=claude-sonnet-4-6 below to spare it.
#
# Set exactly one — if both are present the API key wins. Leave the other blank/removed.
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# READ-ONLY GitHub token, used only to clone/pull the grounding checkout.
# Fine-grained PAT with Contents: Read on the repo (or a classic public_repo PAT).
GITHUB_READ_TOKEN=

# Optional overrides (sensible defaults in apps/griller/src/config.ts):
# GRILLER_MODEL=claude-opus-4-8      # e.g. claude-sonnet-4-6 to ease the Pro quota on token (b)
# GRILLER_GITHUB_REPO=scolacur/personal-dashboard
# GRILLER_PULL_INTERVAL_MS=300000
#
# DATA_DIR, GRILLER_CHECKOUT_DIR, and the HTTP(S)_PROXY vars are set by the
# compose file — don't set them here.
