# Griller worker secrets/config (DECISIONS D-044, PD-266).
#
# Mounted at runtime as the griller container's env_file (see
# docker-compose.egress.yml). Kept SEPARATE from the web app's .env — the
# ANTHROPIC_API_KEY must never live in the user-facing web process.
#
# Copy to the deploy host as griller.env and fill in.

# Claude Agent SDK auth (Opus). The griller reaches api.anthropic.com only via the
# squid proxy; this key can be read in-container but not exfiltrated off-allowlist.
ANTHROPIC_API_KEY=

# READ-ONLY GitHub token, used only to clone/pull the grounding checkout.
# Fine-grained PAT with Contents: Read on the repo (or a classic public_repo PAT).
GITHUB_READ_TOKEN=

# Optional overrides (sensible defaults in apps/griller/src/config.ts):
# GRILLER_MODEL=claude-opus-4-8
# GRILLER_GITHUB_REPO=scolacur/personal-dashboard
# GRILLER_PULL_INTERVAL_MS=300000
#
# DATA_DIR, GRILLER_CHECKOUT_DIR, and the HTTP(S)_PROXY vars are set by the
# compose file — don't set them here.
