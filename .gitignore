.DS_Store
# Version project skills; keep local/machine settings out. `.claude/*` (not `.claude/`)
# so git still descends and honors the negation below. Add `!.claude/settings.json`
# later to also version project permissions; settings.local.json stays ignored.
.claude/*
!.claude/commands/
node_modules/
dist/
.env
data/
# Sortie's per-run workspace scratch (scm.json, the verify-ok hand-off marker) — never
# belongs in a commit; keeping it ignored hardens the after_run hand-off logic (D-046).
.sortie/
apps/web/.svelte-kit/
apps/web/build/

# also match node_modules symlinks/files, not just directories
node_modules
**/node_modules
